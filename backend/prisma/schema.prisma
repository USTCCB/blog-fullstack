generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique @db.VarChar(50)
  email     String   @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  role      Role     @default(USER)
  avatar    String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  posts Post[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

model Post {
  id          String   @id @default(uuid())
  title       String   @db.VarChar(200)
  slug        String   @unique @db.VarChar(200)
  content     String
  excerpt     String?  @db.VarChar(500)
  coverImage  String?  @map("cover_image") @db.VarChar(255)
  authorId    String   @map("author_id")
  status      PostStatus @default(DRAFT)
  viewCount   Int      @default(0) @map("view_count")
  likeCount   Int      @default(0) @map("like_count")
  searchVector String? @map("search_vector")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  publishedAt DateTime? @map("published_at")

  author      User       @relation(fields: [authorId], references: [id])
  tags        PostTag[]
  comments    Comment[]

  @@index([authorId])
  @@index([createdAt])
  @@index([status])
  @@map("posts")
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique @db.VarChar(50)
  slug      String   @unique @db.VarChar(50)
  color     String   @default("#8b5cf6") @db.VarChar(7)
  createdAt DateTime @default(now()) @map("created_at")

  posts PostTag[]

  @@map("tags")
}

model PostTag {
  postId String @map("post_id")
  tagId  String @map("tag_id")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([postId])
  @@index([tagId])
  @@map("post_tags")
}

model Comment {
  id           String        @id @default(uuid())
  postId       String        @map("post_id")
  authorName   String        @map("author_name") @db.VarChar(50)
  authorEmail  String        @map("author_email") @db.VarChar(100)
  content      String
  parentId     String?       @map("parent_id")
  status       CommentStatus @default(PENDING)
  createdAt    DateTime      @default(now()) @map("created_at")

  post  Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@index([postId])
  @@map("comments")
}

enum CommentStatus {
  PENDING
  APPROVED
  SPAM
}
